{
  "id": "app.predictypie.prediction",
  "defs": {
    "main": {
      "key": "tid",
      "type": "record",
      "record": {
        "type": "object",
        "required": ["text", "createdAt", "deadline"],
        "properties": {
          "text": {
            "type": "string",
            "maxGraphemes": 500
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "deadline": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}